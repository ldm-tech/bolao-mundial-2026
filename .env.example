# Configuração do Bolão Mundial 2026
# Copie este arquivo para .env e ajuste os valores antes de rodar.
#
#   cp .env.example .env
#   docker compose up

# Porta em que o servidor escuta
PORT=3000

# Caminho do banco SQLite (dentro do container; mapeado para ./data/ pelo volume)
BOLAO_DB=/data/bolao.db

# Senha do painel /admin — TROQUE EM PRODUÇÃO antes de expor na internet
BOLAO_ADMIN_SENHA=admin

# Segredo para assinar os cookies de sessão — gere um hex aleatório em produção:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOLAO_SESSION_SECRET=troque-por-um-hex-aleatorio
