<%- include('partials/head') %>
<div class="cabecalho-pagina">
  <span class="kicker">Premiação</span>
  <h1>Como o prêmio é dividido</h1>
  <p>O bolão premia o pódio, o campeão da 1ª Fase e quem terminar no meio da tabela.</p>
</div>

<section class="painel">
  <table class="tabela">
    <thead><tr><th>Prêmio</th><th>Posição</th><th class="col-num">% do bolão</th><th>Quem está levando</th></tr></thead>
    <tbody>
      <% premios.forEach(function(p){ %>
        <tr>
          <td><%= p.rotulo %></td>
          <td><%= p.posicao ? p.posicao + 'º' : '—' %></td>
          <td class="col-num"><%= Math.round(p.pct*100) %>%</td>
          <td><%= p.jogador ? p.jogador.nome : '—' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
  <p style="color:var(--muted);font-size:.85rem">Os valores em reais são administrados pela organização.</p>
</section>
<%- include('partials/foot') %>
