<%- include('partials/head') %>

<div class="cabecalho-pagina">
  <span class="kicker">Resultados &amp; Palpites</span>
  <h1>Jogos da Copa</h1>
  <p>Veja o placar real e o palpite de cada um. Toque em "ver palpites" para abrir.</p>
</div>

<nav class="pills" aria-label="Filtrar por fase">
  <% FASES_ORDEM.forEach(function(f){ %>
    <a href="/jogos?fase=<%= f %>" class="<%= faseFiltro === f ? 'ativo' : '' %>"><%= FASE_LABEL[f] %></a>
  <% }); %>
</nav>

<div class="jogos-busca">
  <input type="search" id="busca-jogo" placeholder="🔎 Buscar seleção (ex.: Brasil)" autocomplete="off" aria-label="Buscar seleção" />
  <span class="jogos-busca__vazio" hidden>Nenhum jogo encontrado.</span>
</div>

<div data-auto-refresh data-versao="<%= versao %>">
<%- include('partials/banner-vivo') %>
<% if (lista.length === 0) { %>
  <p class="vazio">Nenhum jogo nesta fase.</p>
<% } %>

<div id="lista-jogos">
<% if (typeof dias !== 'undefined' && dias) { %>
  <%# Fase de grupos: accordion por dia (um aberto por padrão) %>
  <% var DOW = ['dom', 'seg', 'ter', 'qua', 'qui', 'sex', 'sáb']; %>
  <% dias.forEach(function(dia){
       var dt = new Date(dia.data + 'T12:00:00');
       var lbl = DOW[dt.getDay()] + ' · ' + dia.data.split('-').reverse().slice(0, 2).join('/'); %>
    <details class="dia" data-key="dia-<%= dia.data %>" <%- dia.data === diaAberto ? 'open data-inicial="1"' : '' %>>
      <summary class="dia__cab">
        <span class="dia__data"><%= lbl %></span>
        <span class="dia__meta">
          <% if (dia.temAoVivo) { %><span class="selo-vivo"><span class="ponto-vivo"></span>AO VIVO</span><% } %>
          <span class="dia__chip"><%= dia.jogos.length %> jogo<%= dia.jogos.length !== 1 ? 's' : '' %></span>
        </span>
      </summary>
      <div class="dia__jogos">
        <% dia.jogos.forEach(function(item){ %><%- include('partials/jogo-card', { item: item }) %><% }); %>
      </div>
    </details>
  <% }); %>
<% } else { %>
  <%# Demais fases: lista simples %>
  <% lista.forEach(function(item){ %><%- include('partials/jogo-card', { item: item }) %><% }); %>
<% } %>
</div>
</div>

<script src="/jogos-busca.js" defer></script>
<script src="/jogos-fixados.js" defer></script>

<%- include('partials/foot') %>
