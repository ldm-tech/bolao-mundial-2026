<%- include('partials/head') %>

<div class="cabecalho-pagina">
  <span class="kicker">Painel do Organizador</span>
  <h1>Palpites por Participante</h1>
  <p>Selecione um participante para lançar ou editar os palpites dele. Grupos: só gols. Mata-mata: times + gols + pênaltis (se houver).</p>
</div>

<% if (salvou) { %><div class="aviso">✅ Palpites salvos com sucesso!</div><% } %>
<% if (erro) { %><div class="aviso aviso--erro">⚠️ <%= erro %></div><% } %>

<%- include('partials/admin-nav', { abaAtiva: 'palpites' }) %>

<%# Seletor de participante %>
<section class="painel">
  <div class="painel__titulo">
    <h2>Participante</h2>
  </div>
  <div class="painel__corpo">
    <form method="get" action="/admin/palpites" style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap">
      <select name="jogador" style="flex:1;min-width:180px;max-width:340px">
        <option value="">— escolha um participante —</option>
        <% participantes.forEach(function(p){ %>
          <option value="<%= p.id %>" <%= jogador && jogador.id === p.id ? 'selected' : '' %>><%= p.nome_exib %></option>
        <% }); %>
      </select>
      <button class="btn" type="submit">Ver / Editar palpites</button>
      <% if (jogador) { %>
        <a href="/jogador/<%= jogador.id %>" class="btn btn--ghost" target="_blank" rel="noopener">Ver ficha pública</a>
      <% } %>
    </form>
  </div>
</section>

<% if (jogador) { %>

<%# datalist de seleções para os campos de mata-mata %>
<datalist id="selecoes">
  <% selecoes.forEach(function(s){ %><option value="<%= s %>"></option><% }); %>
</datalist>

<form method="post" action="/admin/palpites">
  <input type="hidden" name="jogador_id" value="<%= jogador.id %>" />

  <%# Jogos por fase %>
  <% jogosPorFase.forEach(function(grupo){ %>
    <section class="painel" style="margin-top:1rem">
      <div class="painel__titulo">
        <h2><%= grupo.label %></h2>
        <span class="chip"><%= grupo.jogos.length %> jogo<%= grupo.jogos.length !== 1 ? 's' : '' %></span>
      </div>
      <div class="painel__corpo">

      <% if (grupo.ehGrupos) { %>
        <%# GRUPOS: só gols %>
        <div class="admin-grid">
          <% grupo.jogos.forEach(function(j){ const p = porJogo.get(j.numero) || {}; %>
            <div class="admin-jg">
              <div class="admin-jg__conf">
                <span class="admin-jg__n">Jogo <%= j.numero %></span>
                <%- flag(j.time_casa) %><%= j.time_casa %> <span class="jj-x">×</span> <%- flag(j.time_fora) %><%= j.time_fora %>
              </div>
              <div class="admin-jg__inputs">
                <input type="number" min="0" name="gc_<%= j.numero %>"
                  value="<%= p.gols_casa != null ? p.gols_casa : '' %>"
                  inputmode="numeric" aria-label="Gols <%= j.time_casa %>" />
                <span class="jj-x">×</span>
                <input type="number" min="0" name="gf_<%= j.numero %>"
                  value="<%= p.gols_fora != null ? p.gols_fora : '' %>"
                  inputmode="numeric" aria-label="Gols <%= j.time_fora %>" />
              </div>
            </div>
          <% }); %>
        </div>

      <% } else { %>
        <%# MATA-MATA: times + gols + pênaltis %>
        <div class="admin-grid">
          <% grupo.jogos.forEach(function(j){ const p = porJogo.get(j.numero) || {}; %>
            <div style="background:var(--paper);border:1px solid var(--line);border-radius:10px;padding:0.6rem 0.7rem">
              <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--muted);margin-bottom:.4rem">
                <span class="jogo-card__num">Jogo <%= j.numero %></span>
                <span><%= j.data ? j.data.split('-').reverse().join('/') : '' %><% if (j.cidade) { %> · <%= j.cidade %><% } %></span>
              </div>
              <div style="font-size:.75rem;color:var(--muted);margin-bottom:.3rem">Quem você acha que joga?</div>
              <div class="admin-times">
                <input type="text" name="tc_<%= j.numero %>" list="selecoes"
                  placeholder="Seleção mandante"
                  value="<%= p.time_casa || '' %>" />
                <input type="text" name="tf_<%= j.numero %>" list="selecoes"
                  placeholder="Seleção visitante"
                  value="<%= p.time_fora || '' %>" />
              </div>
              <div class="admin-jogo__meio" style="margin-top:.4rem;justify-content:center">
                <input type="number" min="0" style="max-width:5rem" name="gc_<%= j.numero %>"
                  value="<%= p.gols_casa != null ? p.gols_casa : '' %>"
                  inputmode="numeric" aria-label="Gols mandante" />
                <span style="color:var(--muted)">×</span>
                <input type="number" min="0" style="max-width:5rem" name="gf_<%= j.numero %>"
                  value="<%= p.gols_fora != null ? p.gols_fora : '' %>"
                  inputmode="numeric" aria-label="Gols visitante" />
              </div>
              <div class="admin-penaltis">
                <span>🥅 Pênaltis <small>(se houver)</small></span>
                <div>
                  <input type="number" min="0" name="penc_<%= j.numero %>"
                    value="<%= p.penaltis_casa != null ? p.penaltis_casa : '' %>"
                    inputmode="numeric" aria-label="Pênaltis mandante" />
                  <span style="color:var(--muted)">×</span>
                  <input type="number" min="0" name="penf_<%= j.numero %>"
                    value="<%= p.penaltis_fora != null ? p.penaltis_fora : '' %>"
                    inputmode="numeric" aria-label="Pênaltis visitante" />
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>

      </div>
    </section>
  <% }); %>

  <%# Especiais %>
  <section class="painel" style="margin-top:1rem">
    <div class="painel__titulo">
      <h2>🌟 Palpites Especiais</h2>
    </div>
    <div class="painel__corpo">
      <div class="admin-times" style="grid-template-columns:1fr 1fr 1fr 1fr;max-width:760px">
        <div>
          <label style="font-size:.8rem;font-weight:700">Artilheiro</label>
          <input type="text" name="artilheiro"
            value="<%= especiais.artilheiro || '' %>"
            placeholder="Nome do artilheiro (texto livre)" />
        </div>
        <div>
          <label style="font-size:.8rem;font-weight:700">Campeão</label>
          <input type="text" name="campeao" list="selecoes"
            value="<%= especiais.campeao || '' %>"
            placeholder="Seleção campeã" />
        </div>
        <div>
          <label style="font-size:.8rem;font-weight:700">Finalista 1</label>
          <input type="text" name="finalista_1" list="selecoes"
            value="<%= especiais.finalista_1 || '' %>"
            placeholder="Seleção finalista" />
        </div>
        <div>
          <label style="font-size:.8rem;font-weight:700">Finalista 2</label>
          <input type="text" name="finalista_2" list="selecoes"
            value="<%= especiais.finalista_2 || '' %>"
            placeholder="Seleção finalista" />
        </div>
      </div>
    </div>
  </section>

  <div class="barra-acoes" style="margin-top:1rem">
    <button class="btn" type="submit">💾 Salvar palpites de <%= jogador.nome %></button>
  </div>
</form>

<% } %>

<form method="post" action="/admin/logout" style="margin-top:1.5rem">
  <button class="btn btn--ghost" type="submit">Sair</button>
</form>

<%- include('partials/foot') %>
