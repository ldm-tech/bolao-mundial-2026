<%- include('partials/head') %>
<div class="cabecalho-pagina">
  <span class="kicker">Painel do Organizador</span>
  <h1>Contatos & Premiação</h1>
  <p>Edite nome de exibição, e-mail, WhatsApp e marque quem pagou. Estes dados são privados (não aparecem no site aberto).</p>
</div>
<% if (salvou) { %><div class="aviso">✅ Contatos salvos!</div><% } %>

<section class="painel">
  <div class="painel__titulo"><h2>Premiação (valores)</h2><span class="chip"><%= nPagantes %> pagantes</span></div>
  <p>Pool = R$ <%= valorAposta %> × <%= nPagantes %> = <strong>R$ <%= pool.toLocaleString('pt-BR') %></strong></p>
  <table class="tabela">
    <thead><tr><th>Prêmio</th><th>Posição</th><th class="col-num">%</th><th class="col-num">R$</th><th>Quem leva</th></tr></thead>
    <tbody>
      <% premios.forEach(function(p){ %>
        <tr><td><%= p.rotulo %></td><td><%= p.posicao ? p.posicao+'º' : '—' %></td>
        <td class="col-num"><%= Math.round(p.pct*100) %>%</td>
        <td class="col-num">R$ <%= p.valorReais.toLocaleString('pt-BR') %></td>
        <td><%= p.jogador ? p.jogador.nome : '—' %></td></tr>
      <% }); %>
    </tbody>
  </table>
</section>

<div class="barra-acoes" style="justify-content:flex-start;gap:.5rem;margin-bottom:.6rem">
  <form method="post" action="/admin/contatos/pago-todos">
    <button class="btn" type="submit">✅ Marcar todos como pago</button>
  </form>
  <form method="post" action="/admin/contatos/pago-todos">
    <input type="hidden" name="desmarcar" value="1" />
    <button class="btn btn--ghost" type="submit">Desmarcar todos</button>
  </form>
</div>

<form method="post" action="/admin/contatos">
  <section class="painel">
    <div class="painel__titulo"><h2>Participantes</h2><span class="chip"><%= jogadores.length %></span></div>
    <table class="tabela">
      <thead><tr><th>Nome (exibição)</th><th>E-mail</th><th>WhatsApp</th><th>Pago</th></tr></thead>
      <tbody>
        <% jogadores.forEach(function(j){ %>
          <tr>
            <td><input type="text" name="nome_<%= j.id %>" value="<%= j.nome %>" style="width:100%" /></td>
            <td><input type="email" name="email_<%= j.id %>" value="<%= j.email || '' %>" style="width:100%" /></td>
            <td>
              <input type="text" name="whats_<%= j.id %>" value="<%= j.whatsapp || '' %>" style="width:8rem" />
              <% if (j.whatsapp) { %><a href="https://wa.me/55<%= String(j.whatsapp).replace(/\D/g,'') %>" target="_blank" rel="noopener" aria-label="WhatsApp">💬</a><% } %>
            </td>
            <td style="text-align:center"><input type="checkbox" name="pago_<%= j.id %>" <%= j.pago ? 'checked' : '' %> /></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
    <div class="barra-acoes"><button class="btn" type="submit">💾 Salvar contatos</button></div>
  </section>
</form>
<%- include('partials/foot') %>
